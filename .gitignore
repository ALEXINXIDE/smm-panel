# ==============================================================================
# .gitignore — Production-Safe Exclusion Rules
# ==============================================================================
# CRITICAL: These patterns prevent sensitive files and build artifacts from
# being committed to version control.
# ==============================================================================

# ── Environment & Secrets ─────────────────────────────────────────────────────
# NEVER commit .env — it contains database passwords, API keys, and APP_KEY.
# APP_KEY in git = anyone can forge session cookies and decrypt all user data.
.env
.env.*
!.env.example        # The example template IS committed (no real values)

# ── Database Files ────────────────────────────────────────────────────────────
# SQLite databases must never be in git — they contain real user data.
# The 20MB database.sqlite in the original repo is a serious data exposure.
*.sqlite
*.sqlite3
*.db

# ── Vendor & Dependencies ─────────────────────────────────────────────────────
# Generated by composer/npm — never commit these
/vendor/
/node_modules/

# Composer binary — download it, don't commit it
composer.phar

# ── Build Artifacts ───────────────────────────────────────────────────────────
/public/build/
/public/hot/

# ── Laravel Framework Cache ───────────────────────────────────────────────────
# These are generated at deployment time by php artisan config:cache etc.
/bootstrap/cache/*.php
!/bootstrap/cache/.gitkeep

# ── Storage ───────────────────────────────────────────────────────────────────
/storage/app/*
!/storage/app/.gitkeep
!/storage/app/public/.gitkeep

/storage/framework/cache/*
!/storage/framework/cache/.gitkeep
!/storage/framework/cache/data/.gitkeep

/storage/framework/sessions/*
!/storage/framework/sessions/.gitkeep

/storage/framework/views/*
!/storage/framework/views/.gitkeep

/storage/logs/*
!/storage/logs/.gitkeep

# ── Testing ───────────────────────────────────────────────────────────────────
.phpunit.result.cache
coverage.xml
/coverage/

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Docker Local Overrides ─────────────────────────────────────────────────────
docker-compose.override.yml
docker-compose.local.yml

# Unknown/temporary files
tasktt
